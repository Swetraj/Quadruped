<?xml version="1.0"?>
<robot name="quadruped">
    <!-- ================================================================
       BASE
       ================================================================ -->
    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.5" />
            <inertia
                ixx="0.001"
                ixy="0"
                ixz="0"
                iyy="0.001"
                iyz="0"
                izz="0.001" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="meshes/base_body.stl" scale="1 1 1" />
            </geometry>
            <material name="light_blue">
                <color rgba="0.615686 0.811765 0.929412 1" />
            </material>
        </visual>
        <!-- FIX: aligned origin with inertial z=0.005 -->
        <collision>
            <origin xyz="0 0 0.005" rpy="0 0 0" />
            <geometry>
                <box size="0.08 0.08 0.03" />
            </geometry>
        </collision>
    </link>

    <!-- ================================================================
       FRONT-LEFT LEG  (FL)
       ================================================================ -->
    <link name="shoulder_FL">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.05" />
            <inertia
                ixx="0.00002"
                ixy="0"
                ixz="0"
                iyy="0.00002"
                iyz="0"
                izz="0.00002" />
        </inertial>
        <visual>
            <origin xyz="-1.68455e-18 0.0118 -0.0116051" rpy="0 0 0" />
            <geometry>
                <mesh filename="meshes/servo.stl" scale="1 1 1" />
            </geometry>
            <material name="purple">
                <color rgba="0.682353 0.333333 0.737255 1" />
            </material>
        </visual>

    </link>
    <joint name="hip_ab_FL" type="fixed">
        <origin xyz="0.0182 0.02155 0.005" rpy="0 0 -1.5708" />
        <parent link="base_link" />
        <child link="shoulder_FL" />
    </joint>

    <link name="femur_FL">
        <inertial>
            <origin xyz="0 0 -0.02" rpy="0 0 0" />
            <mass value="0.02" />
            <inertia
                ixx="0.00001"
                ixy="0"
                ixz="0"
                iyy="0.00001"
                iyz="0"
                izz="0.00001" />
        </inertial>
        <visual>
            <origin xyz="-0.00018 0.019 -0.03" rpy="0 0 0" />
            <geometry>
                <mesh filename="meshes/femur.stl" scale="1 1 1" />
            </geometry>
            <material name="light_blue">
                <color rgba="0.615686 0.811765 0.929412 1" />
            </material>
        </visual>
    </link>
    <joint name="hip_FL" type="revolute">
        <origin xyz="-0.00535 0.0059 0.0151949" rpy="0 0 0" />
        <axis xyz="0 0 -1" />
        <parent link="shoulder_FL" />
        <child link="femur_FL" />
        <limit effort="10" velocity="5" lower="-0.67" upper="0.67" />
        <dynamics damping="0.1" friction="0.0" />
    </joint>

    <link name="lower_leg_FL">
        <inertial>
            <origin xyz="0 0 -0.015" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia
                ixx="0.000005"
                ixy="0"
                ixz="0"
                iyy="0.000005"
                iyz="0"
                izz="0.000005" />
        </inertial>
        <visual>
            <origin xyz="0.00535 0.0059 -0.0267" rpy="0 0 0" />
            <geometry>
                <mesh filename="meshes/servo.stl" scale="1 1 1" />
            </geometry>
            <material name="purple">
                <color rgba="0.682353 0.333333 0.737255 1" />
            </material>
        </visual>
    </link>
    <joint name="knee_FL" type="revolute">
        <origin xyz="0.01282 0.038 -0.024" rpy="0 1.5708 0" />
        <axis xyz="0 0 1" />
        <parent link="femur_FL" />
        <child link="lower_leg_FL" />
        <limit effort="10" velocity="5" lower="-0.7" upper="1.5708" />
        <dynamics damping="0.1" friction="0.0" />
    </joint>

    <link name="foot_FL">
        <inertial>
            <origin xyz="0 0 -0.015" rpy="0 0 0" />
            <mass value="0.01" />
            <inertia
                ixx="0.000005"
                ixy="0"
                ixz="0"
                iyy="0.000005"
                iyz="0"
                izz="0.000005" />
        </inertial>
        <visual>
            <origin xyz="-0.0043 0.008 -0.01625" rpy="0 0 0" />
            <geometry>
                <mesh filename="meshes/leg.stl" scale="1 1 1" />
            </geometry>
            <material name="light_blue">
                <color rgba="0.615686 0.811765 0.929412 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="-0.006 0 -0.02195" rpy="0 0 0" />
            <geometry>
                <cylinder radius="0.007" length="0.07" />
            </geometry>
        </collision>


    </link>
    <joint name="ankle_FL" type="fixed">
        <origin xyz="0.00535 0.0059 -0.01875" rpy="-1.5708 0 1.5708" />
        <parent link="lower_leg_FL" />
        <child link="foot_FL" />
    </joint>

